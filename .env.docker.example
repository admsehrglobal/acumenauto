ENV_STATE=development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web

SECRET_KEY=changeme-generate-with-django-utils-crypto-get_random_string

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/acumenauto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=acumenauto

# Django
DJANGO_SETTINGS_MODULE=acumenauto.settings
GUNICORN_WORKERS=4

# DCI portal
DCI_USERNAME=
DCI_PASSWORD=
# Incluir ?__tenant=<uuid> al final. Obtenido del popup post-SSO (ej: /reports?__tenant=f51c...).
DCI_REPORT_URL=
DCI_REPORT_BUTTON_NAME=
# Segundo reporte (mismo tenant, otro report group y otro botón).
DCI_REPORT_URL_2=
DCI_REPORT_BUTTON_NAME_2=
# Tercer reporte (Vendor Authorization Accrual Balances) — chunked.
# Excede 150k filas/export, se baja partido en N chunks. Start date fija;
# end date la lee el scraper del filtro al cargar el reporte.
DCI_REPORT_URL_3=
DCI_REPORT_BUTTON_NAME_3=
DCI_REPORT_3_START_DATE=2025-05-30
# Numero de chunks: editable desde /settings/#reports en el dashboard (DB-backed).

# Notifications
NOTIFICATION_EMAIL=

# Email (Brevo)
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=info@njdddgs.com

# Celery (broker + result backend)
CELERY_BROKER_URL=redis://redis:6379/0

# Admin user creado por la migration 0003. Si no estan setteadas, no se crea nada.
# Es idempotente: si el usuario ya existe, no hace nada.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
